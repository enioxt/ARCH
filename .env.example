# EGOS Arch — Environment Variables
# Copy to .env and fill in values

# OpenRouter API key (REQUIRED for AI chat + briefing analysis)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Google Gemini API key (optional, for direct Gemini access)
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Supabase (optional, for persistence)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# Application URL
APP_URL=https://arch.egos.ia.br

# Node environment
NODE_ENV=production
