# EGOS Arch — Environment Variables
# Copy to .env and fill in values
# ⚠️ NEVER commit .env file! It's in .gitignore for security.

# === AI PROVIDERS ===

# OpenRouter API key (REQUIRED for AI chat + briefing analysis)
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE

# Gemini API key (for multimodal - sketches, vision extraction)
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# Anthropic Claude API (optional, for fallback reasoning)
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# OpenAI API (optional, for GPT-5.4 fallback)
OPENAI_API_KEY=YOUR_OPENAI_KEY_HERE

# === IMAGE & VIDEO GENERATION ===

# fal.ai — PRIMARY provider (Flux, Recraft, Luma, Veo)
FAL_KEY=YOUR_FAL_KEY_HERE

# Together AI — BUDGET provider (SDXL, Flux Schnell free)
TOGETHER_API_KEY=YOUR_TOGETHER_KEY_HERE

# Google AI Studio — Imagen 4 (free tier available)
GOOGLE_AI_API_KEY=YOUR_GOOGLE_AI_KEY_HERE

# === BUDGET MODULE APIs ===

# Exa API — Agentic search for price discovery ($7/1k searches)
EXA_API_KEY=YOUR_EXA_API_KEY_HERE

# Brave Search API — Fallback search provider ($5/1k requests)
BRAVE_API_KEY=YOUR_BRAVE_API_KEY_HERE

# Firecrawl API — Web scraping for supplier prices ($16/mo)
FIRECRAWL_API_KEY=YOUR_FIRECRAWL_API_KEY_HERE

# Perplexity API — Deep research on pricing ($5/1k requests)
PERPLEXITY_API_KEY=YOUR_PERPLEXITY_API_KEY_HERE

# === DATABASE & PERSISTENCE ===

# PostgreSQL (for budget and project persistence)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=egos_arch
POSTGRES_USER=sinapi_user
POSTGRES_PASSWORD=sinapi_pass

# Supabase (optional, alternative to PostgreSQL)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# === APPLICATION ===

# Application URL (for OAuth redirects, etc)
APP_URL=https://arch.egos.ia.br

# Node environment (development, production)
NODE_ENV=production

# Debug mode (set to "true" for verbose logging)
DEBUG=false
