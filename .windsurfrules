## 🛠️ Coding Standards

### TypeScript
```typescript
// ✅ GOOD: Explicit types, structured, readable
type BudgetItem = {
  id: string;
  name: string;
  quantity: number;
  unit: string;
  prices: {
    low: number;
    mid: number;
    high: number;
  };
  sources: CostSource[];
  confidenceScore: number;
};

// ❌ BAD: any, implicit types, unclear structure
const item: any = { ... };
```

### React Components
- Functional components only
- Hooks for state and effects
- Props interfaces always explicit
- No inline styles (use Tailwind)

```tsx
// ✅ GOOD
type ProposalCardProps = {
  proposal: DesignProposal;
  onSelect: (id: string) => void;
  isSelected: boolean;
};

export function ProposalCard({ proposal, onSelect, isSelected }: ProposalCardProps) {
  return (
    <Card className={cn("p-4", isSelected && "ring-2 ring-blue-500")}>
      {/* ... */}
    </Card>
  );
}

// ❌ BAD
export function ProposalCard(props: any) {
  return <div style={{ padding: "16px" }}>{/* ... */}</div>;
}
```

### API Routes
- RESTful conventions
- Versioned endpoints (`/api/v1/*`)
- Structured error responses
- Cost tracking on every LLM call

```typescript
// ✅ GOOD
app.post("/api/budget/build-from-project", async (req, res) => {
  const startTime = Date.now();
  try {
    const { projectId } = req.body;

    const budget = await budgetResearcher.buildBudget(projectId);

    telemetry.emit({
      event_type: "budget_generated",
      latency_ms: Date.now() - startTime,
      cost_usd: budget.apiCost,
      metadata: { projectId, item_count: budget.items.length }
    });

    res.json({ success: true, data: budget });
  } catch (error) {
    res.status(500).json({
      success: false,
      error: error.message,
      timestamp: new Date().toISOString()
    });
  }
});

// ❌ BAD
app.post("/budget", (req, res) => {
  const budget = makeBudget(req.body); // no error handling, no telemetry
  res.send(budget);
});
```

### State Management (Zustand)
- One store per domain
- Selectors for derived state
- Actions as methods, not external functions

```typescript
// ✅ GOOD
export const useBudgetStore = create<BudgetStore>((set, get) => ({
  budgets: {},

  addBudget: (projectId: string, budget: BudgetReport) => {
    set(state => ({
      budgets: { ...state.budgets, [projectId]: budget }
    }));
  },

  getLatestBudget: (projectId: string) => {
    return get().budgets[projectId];
  }
}));

// ❌ BAD: Global state outside store
let globalBudget: any;
```

