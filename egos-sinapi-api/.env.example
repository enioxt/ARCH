# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=egos_sinapi
DB_USER=sinapi_user
DB_PASS=sinapi_pass

# API Configuration
API_PORT=8000
API_HOST=0.0.0.0

# Application
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# SINAPI Configuration
SINAPI_DOWNLOAD_DIR=./downloads
SINAPI_RETENTION_DAYS=90

# Job Scheduling
SCHEDULER_ENABLED=True
SCHEDULER_TIMEZONE=America/Sao_Paulo

# Optional: Caixa SINAPI access (if different from public)
SINAPI_API_URL=https://www.caixa.gov.br/Downloads/sinapi/Tabelas_SINAPI/

# Notification (optional)
SLACK_WEBHOOK_URL=
EMAIL_ALERTS_ENABLED=False
EMAIL_RECIPIENTS=

# Security
ADMIN_SECRET_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key

# Proxy (if needed)
HTTP_PROXY=
HTTPS_PROXY=
